# Build artifacts
build/
build-*/
*.o
*.obj
*.a
*.so
*.dylib

# Generated tick streams (large) — tiny.ticks is the committed golden file
data/*.ticks
!data/tiny.ticks
data/large.ticks
data/public.ticks
data/hidden.ticks
data/*.bin

# Generated reference tables (large) — tiny.agg.json is committed
data/*.agg.json
!data/tiny.agg.json

# Scaling sweep CSVs from tools/plot_scaling.py
data/scaling*.csv
scaling*.png

# perf / profiling output
perf.data
perf.data.old
cachegrind.out.*
callgrind.out.*
*.svg                  # flame graphs

# Python bytecode
__pycache__/
*.pyc

# Editor / OS noise
.vscode/
.idea/
.cache/
.DS_Store
*.swp
*~

# CMake-generated files outside the build/ dir
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json

# Sanitizer logs
asan.log.*
ubsan.log.*
tsan.log.*
